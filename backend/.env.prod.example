# Production Environment Configuration
# 生产环境配置文件

# ==================== 应用配置 ====================
APP_NAME=RAGFlow
APP_VERSION=0.1.0
DEBUG=False
ENVIRONMENT=production

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=8000

# ==================== 数据库配置 ====================
# MySQL配置（生产环境必须使用强密码）
MYSQL_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD
MYSQL_DATABASE=ragflow_prod
MYSQL_USER=ragflow_user_prod
MYSQL_PASSWORD=CHANGE_THIS_DB_PASSWORD
MYSQL_PORT=3306

# 数据库连接池配置
DATABASE_URL=mysql+pymysql://ragflow_user_prod:CHANGE_THIS_DB_PASSWORD@mysql:3306/ragflow_prod
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600

# ==================== Redis配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_DB=0

# ==================== JWT配置 ====================
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== 密码安全 ====================
BCRYPT_ROUNDS=12

# ==================== 登录安全 ====================
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# ==================== 通义千问API ====================
DASHSCOPE_API_KEY=your-production-dashscope-api-key-here
TONGYI_MODEL_NAME=qwen-turbo
TONGYI_TEMPERATURE=0.7
TONGYI_MAX_TOKENS=2000

# ==================== 向量数据库 ====================
CHROMA_PERSIST_DIRECTORY=/app/vector_db
CHROMA_COLLECTION_NAME=documents_prod

# ==================== 嵌入模型 ====================
EMBEDDING_MODEL=text-embedding-v1

# ==================== 文件上传 ====================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ==================== 文档处理 ====================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ==================== RAG配置 ====================
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# ==================== 用户配额 ====================
DEFAULT_MONTHLY_QUOTA=100000

# ==================== 速率限制 ====================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_LLM_PER_MINUTE=20

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ==================== CORS配置 ====================
# 生产环境应该配置具体的域名，不要使用*
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOW_CREDENTIALS=True

# ==================== 监控配置 ====================
ENABLE_METRICS=True
METRICS_PORT=9090

# ==================== 后台任务 ====================
ENABLE_SCHEDULER=True
QUOTA_RESET_CRON=0 0 1 * *

# ==================== WebSocket配置 ====================
WS_HEARTBEAT_INTERVAL=30

# ==================== OpenClaw网关配置 ====================
OPENCLAW_GATEWAY_URL=http://openclaw-gateway:19001
OPENCLAW_TIMEOUT=30.0
OPENCLAW_MAX_RETRIES=3
OPENCLAW_ENABLED=True
# API Token列表（逗号分隔）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
OPENCLAW_API_TOKENS=CHANGE_THIS_TOKEN_1,CHANGE_THIS_TOKEN_2

# ==================== Web Scraper配置 (Phase 2) ====================
# 最大并发采集任务数
SCRAPER_MAX_CONCURRENT_TASKS=3
# 默认超时时间（毫秒）
SCRAPER_DEFAULT_TIMEOUT=30000
# URL白名单（逗号分隔，留空表示允许所有）
# 示例: example.com,*.example.com,blog.example.com
SCRAPER_URL_WHITELIST=
# 是否启用截图功能（生产环境建议关闭以节省资源）
SCRAPER_ENABLE_SCREENSHOT=False

# ==================== 前端配置 ====================
FRONTEND_PORT=80
BACKEND_PORT=8000
